<Window x:Class="VirtualFunds.WPF.Views.ScheduledDepositsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="הפקדות מתוזמנות"
        Height="520" Width="700"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft"
        Background="{StaticResource BackgroundBrush}"
        TextElement.Foreground="{StaticResource TextPrimaryBrush}"
        TextElement.FontFamily="{materialDesign:MaterialDesignFont}">

    <DockPanel>

        <!-- Purple header band with title + create button -->
        <Border DockPanel.Dock="Top" Style="{StaticResource HeaderBarStyle}">
            <DockPanel>
                <Button Content="+ חדש"
                        Command="{Binding CreateScheduledDepositCommand}"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"
                        Style="{StaticResource HeaderPrimaryButtonStyle}"
                        DockPanel.Dock="Left" />
                <TextBlock Text="הפקדות מתוזמנות"
                           Style="{StaticResource HeaderTitleStyle}"
                           HorizontalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- Error message -->
        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding ErrorMessage}"
                   Foreground="{StaticResource ErrorBrush}"
                   TextWrapping="Wrap"
                   Margin="16,8,16,0"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />

        <!-- Loading indicator -->
        <TextBlock DockPanel.Dock="Top"
                   Text="טוען..."
                   Style="{StaticResource MutedLabelStyle}"
                   Margin="16,4,16,0"
                   Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <!-- Bottom action buttons -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <Button Content="ערוך"
                        Command="{Binding EditScheduledDepositCommand}"
                        CommandParameter="{Binding SelectedDeposit}"
                        IsEnabled="{Binding CanExecuteDepositOperation}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="10,6" />
                <Button Content="הפעל/השבת"
                        Command="{Binding ToggleEnabledCommand}"
                        CommandParameter="{Binding SelectedDeposit}"
                        IsEnabled="{Binding CanExecuteDepositOperation}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="10,6"
                        Margin="8,0,0,0" />
                <Button Content="מחק"
                        Command="{Binding DeleteScheduledDepositCommand}"
                        CommandParameter="{Binding SelectedDeposit}"
                        IsEnabled="{Binding CanExecuteDepositOperation}"
                        Style="{StaticResource DangerButtonStyle}"
                        Padding="10,6"
                        Margin="8,0,0,0" />
                <Button Content="סגור"
                        IsCancel="True"
                        Style="{StaticResource GhostButtonStyle}"
                        Padding="10,6"
                        Margin="24,0,0,0" />
            </StackPanel>
        </Border>

        <!-- Content area -->
        <Grid Margin="16,8,16,0">
            <!-- Empty state -->
            <TextBlock x:Name="EmptyStateText"
                       Text="אין הפקדות מתוזמנות."
                       Style="{StaticResource MutedLabelStyle}"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="Collapsed" />

            <!-- Deposit list -->
            <ListView x:Name="DepositListView"
                      ItemsSource="{Binding ScheduledDeposits}"
                      SelectedItem="{Binding SelectedDeposit}"
                      BorderThickness="1"
                      BorderBrush="{StaticResource CardBorderBrush}"
                      Background="{StaticResource SurfaceBrush}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="שם" Width="120"
                                        DisplayMemberBinding="{Binding Name}" />
                        <GridViewColumn Header="קרן" Width="100"
                                        DisplayMemberBinding="{Binding FundName}" />
                        <GridViewColumn Header="סכום" Width="90">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FormattedAmount}"
                                               FlowDirection="LeftToRight"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               FontWeight="SemiBold" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="תזמון" Width="160"
                                        DisplayMemberBinding="{Binding FormattedSchedule}" />
                        <GridViewColumn Header="הרצה הבאה" Width="120">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FormattedNextRun}"
                                               FlowDirection="LeftToRight"
                                               Style="{StaticResource MutedLabelStyle}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="מצב" Width="60"
                                        DisplayMemberBinding="{Binding StatusLabel}" />
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>

    </DockPanel>

    <!-- Triggers for empty state visibility -->
    <Window.Style>
        <Style TargetType="Window">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                    <Setter Property="Tag" Value="empty" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Style>
</Window>
