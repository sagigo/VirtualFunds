<Window x:Class="VirtualFunds.WPF.Views.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="כניסה"
        Width="380"
        Height="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FlowDirection="RightToLeft"
        Background="{StaticResource BackgroundBrush}"
        TextElement.Foreground="{StaticResource TextPrimaryBrush}"
        TextElement.FontFamily="{materialDesign:MaterialDesignFont}">

    <DockPanel>

        <!-- Purple header band with app title -->
        <Border DockPanel.Dock="Top" Style="{StaticResource HeaderBarStyle}">
            <TextBlock Text="קרנות וירטואליות"
                       Style="{StaticResource HeaderTitleStyle}"
                       HorizontalAlignment="Center" />
        </Border>

        <!-- Form body -->
        <Border Style="{StaticResource DialogCardStyle}">
            <StackPanel Height="272" VerticalAlignment="Top">

                <!-- Form heading — changes with mode -->
                <TextBlock FontSize="15"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource TextMutedBrush}"
                           Margin="0,0,0,20">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="כניסה" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSignUpMode}" Value="True">
                                    <Setter Property="Text" Value="הרשמה" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Email -->
                <TextBlock Text="דוא״ל" Style="{StaticResource FieldLabelStyle}" />
                <TextBox x:Name="EmailBox"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         FlowDirection="LeftToRight"
                         Margin="0,0,0,12"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" />

                <!-- Password -->
                <TextBlock Text="סיסמה" Style="{StaticResource FieldLabelStyle}" />
                <!-- PasswordBox does not support data binding (by WPF design). -->
                <!-- The code-behind handles PasswordChanged and forwards to the ViewModel. -->
                <PasswordBox x:Name="PasswordBox"
                             FlowDirection="LeftToRight"
                             Margin="0,0,0,12"
                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                             PasswordChanged="PasswordBox_PasswordChanged" />

                <!-- Error message — hidden when empty -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource ErrorBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />

                <!-- Submit button — content switches between sign-in and sign-up mode -->
                <Button Command="{Binding SubmitCommand}"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,10">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                            <Setter Property="Content" Value="כנס" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSignUpMode}" Value="True">
                                    <Setter Property="Content" Value="הירשם" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Loading indicator — visible only while loading -->
                <TextBlock Text="טוען..."
                           HorizontalAlignment="Center"
                           Style="{StaticResource MutedLabelStyle}"
                           Margin="0,0,0,10"
                           Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <!-- Mode toggle link — content switches between sign-in and sign-up mode -->
                <Button Command="{Binding ToggleModeCommand}"
                        HorizontalAlignment="Center">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource LinkButtonStyle}">
                            <Setter Property="Content" Value="אין לך חשבון? הירשם כאן" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSignUpMode}" Value="True">
                                    <Setter Property="Content" Value="יש לך חשבון? כנס" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>
        </Border>

    </DockPanel>
</Window>
