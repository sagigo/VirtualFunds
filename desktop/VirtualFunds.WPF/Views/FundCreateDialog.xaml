<Window x:Class="VirtualFunds.WPF.Views.FundCreateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="קרן חדשה"
        Height="230" Width="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FlowDirection="RightToLeft">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Fund name label -->
        <TextBlock Grid.Row="0"
                   Text="שם הקרן:"
                   Margin="0,0,0,6" />

        <!-- Fund name input -->
        <TextBox Grid.Row="1"
                 x:Name="NameTextBox"
                 Margin="0,0,0,12"
                 Padding="4"
                 MaxLength="100" />

        <!-- Amount label -->
        <TextBlock Grid.Row="2"
                   Text="סכום התחלתי ₪:"
                   Margin="0,0,0,6" />

        <!-- Amount input (LTR for numeric entry) -->
        <TextBox Grid.Row="3"
                 x:Name="AmountTextBox"
                 Margin="0,0,0,2"
                 Padding="4"
                 FlowDirection="LeftToRight"
                 MaxLength="20" />

        <!-- Amount hint + validation error -->
        <TextBlock Grid.Row="4"
                   x:Name="AmountHintText"
                   Text="(אופציונלי — ברירת מחדל: 0)"
                   Foreground="Gray"
                   FontSize="11"
                   Margin="0,0,0,8" />

        <!-- Buttons -->
        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left">
            <Button Content="אישור"
                    MinWidth="70"
                    Padding="12,4"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="OkButton_Click" />
            <Button Content="ביטול"
                    MinWidth="70"
                    Padding="12,4"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
