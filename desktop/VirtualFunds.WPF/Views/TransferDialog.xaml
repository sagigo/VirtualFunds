<Window x:Class="VirtualFunds.WPF.Views.TransferDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="העברה בין קרנות"
        Height="250" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FlowDirection="RightToLeft">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Source fund (read-only) -->
        <TextBlock Grid.Row="0"
                   Text="מקרן:"
                   Margin="0,0,0,4" />
        <TextBlock Grid.Row="1"
                   x:Name="SourceFundText"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12" />

        <!-- Destination fund -->
        <TextBlock Grid.Row="2"
                   Text="לקרן:"
                   Margin="0,0,0,4" />
        <ComboBox Grid.Row="3"
                  x:Name="DestinationComboBox"
                  DisplayMemberPath="Name"
                  Margin="0,0,0,12"
                  Padding="4" />

        <!-- Amount -->
        <TextBlock Grid.Row="4"
                   Text="סכום ₪:"
                   Margin="0,0,0,4" />
        <TextBox Grid.Row="5"
                 x:Name="AmountTextBox"
                 Margin="0,0,0,2"
                 Padding="4"
                 FlowDirection="LeftToRight"
                 MaxLength="20" />

        <!-- Validation error -->
        <TextBlock Grid.Row="6"
                   x:Name="HintText"
                   Text=""
                   Foreground="Gray"
                   FontSize="11"
                   Margin="0,4,0,0" />

        <!-- Buttons -->
        <StackPanel Grid.Row="7"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left">
            <Button Content="העבר"
                    MinWidth="70"
                    Padding="12,4"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="OkButton_Click" />
            <Button Content="ביטול"
                    MinWidth="70"
                    Padding="12,4"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
