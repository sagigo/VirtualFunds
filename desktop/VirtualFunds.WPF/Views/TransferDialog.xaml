<Window x:Class="VirtualFunds.WPF.Views.TransferDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="העברה בין קרנות"
        Height="300"
        Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FlowDirection="RightToLeft"
        Background="{StaticResource BackgroundBrush}"
        TextElement.Foreground="{StaticResource TextPrimaryBrush}"
        TextElement.FontFamily="{materialDesign:MaterialDesignFont}">

    <DockPanel>
        <!-- Purple accent strip at top of dialog -->
        <Border DockPanel.Dock="Top"
                Height="4"
                Background="{StaticResource PrimaryBrush}" />

        <!-- Form content -->
        <Border Style="{StaticResource DialogCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Source fund (read-only) -->
                <TextBlock Grid.Row="0"
                           Text="מקרן:"
                           Style="{StaticResource FieldLabelStyle}" />
                <TextBlock Grid.Row="1"
                           x:Name="SourceFundText"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryBrush}"
                           Margin="0,0,0,12" />

                <!-- Destination fund -->
                <TextBlock Grid.Row="2"
                           Text="לקרן:"
                           Style="{StaticResource FieldLabelStyle}" />
                <ComboBox Grid.Row="3"
                          x:Name="DestinationComboBox"
                          DisplayMemberPath="Name"
                          Margin="0,0,0,12" />

                <!-- Amount -->
                <TextBlock Grid.Row="4"
                           Text="סכום ₪:"
                           Style="{StaticResource FieldLabelStyle}" />
                <TextBox Grid.Row="5"
                         x:Name="AmountTextBox"
                         Margin="0,0,0,2"
                         FlowDirection="LeftToRight"
                         MaxLength="20"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" />

                <!-- Validation hint -->
                <TextBlock Grid.Row="6"
                           x:Name="HintText"
                           Text=""
                           Style="{StaticResource HintTextStyle}"
                           Margin="0,4,0,0" />

                <!-- Buttons -->
                <StackPanel Grid.Row="7"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left">
                    <Button Content="העבר"
                            MinWidth="70"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Padding="12,6"
                            Margin="0,0,8,0"
                            IsDefault="True"
                            Click="OkButton_Click" />
                    <Button Content="ביטול"
                            MinWidth="70"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="12,6"
                            IsCancel="True" />
                </StackPanel>
            </Grid>
        </Border>
    </DockPanel>
</Window>
