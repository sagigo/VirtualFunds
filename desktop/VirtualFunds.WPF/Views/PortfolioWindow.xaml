<Window x:Class="VirtualFunds.WPF.Views.PortfolioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="{Binding PortfolioName, StringFormat='קרנות וירטואליות — {0}'}"
        Height="600" Width="1100"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft"
        Background="{StaticResource BackgroundBrush}"
        TextElement.Foreground="{StaticResource TextPrimaryBrush}"
        TextElement.FontFamily="{materialDesign:MaterialDesignFont}">

    <DockPanel>

        <!-- ══════════════════════════════════════════════════
             HEADER — full-width purple bar
             RTL order: [back btn | create btn | total] ... [portfolio name]
             ══════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top" Style="{StaticResource HeaderBarStyle}">
            <DockPanel>
                <!-- Back button (right side in RTL = visual left) -->
                <Button Content="→ חזרה"
                        Command="{Binding GoBackCommand}"
                        Style="{StaticResource GhostWhiteButtonStyle}"
                        VerticalAlignment="Center"
                        DockPanel.Dock="Right" />

                <!-- Create fund button -->
                <Button Content="+ קרן חדשה"
                        Command="{Binding CreateFundCommand}"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"
                        Style="{StaticResource HeaderPrimaryButtonStyle}"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0"
                        DockPanel.Dock="Left" />

                <!-- Portfolio total (left side in RTL) -->
                <TextBlock Text="{Binding FormattedTotal}"
                           Style="{StaticResource HeaderTotalStyle}"
                           DockPanel.Dock="Left"
                           Margin="12,0,0,0"
                           FlowDirection="LeftToRight" />

                <!-- Portfolio name fills the center -->
                <TextBlock Text="{Binding PortfolioName}"
                           Style="{StaticResource HeaderTitleStyle}"
                           HorizontalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- Portfolio-level error message -->
        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding ErrorMessage}"
                   Foreground="{StaticResource ErrorBrush}"
                   TextWrapping="Wrap"
                   Margin="16,8,16,0"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />

        <!-- ══════════════════════════════════════════════════
             BOTTOM — portfolio-level actions
             ══════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <Button Content="שנה שם תיק"
                        Command="{Binding RenamePortfolioCommand}"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,6" />
                <Button Content="עדכון שווי"
                        Command="{Binding RevaluePortfolioCommand}"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,6"
                        Margin="8,0,0,0" />
                <Button Content="מחק תיק"
                        Command="{Binding DeletePortfolioCommand}"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"
                        Style="{StaticResource DangerButtonStyle}"
                        Padding="12,6"
                        Margin="8,0,0,0" />
                <Button Content="הפקדות מתוזמנות"
                        Command="{Binding ManageScheduledDepositsCommand}"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,6"
                        Margin="8,0,0,0" />
                <Button Content="ייצוא תמונת מצב"
                        Command="{Binding ExportSnapshotCommand}"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,6"
                        Margin="8,0,0,0" />
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════
             CENTER — Side-by-side split
             Funds (right in RTL) | Splitter | History (left in RTL)
             ══════════════════════════════════════════════════ -->
        <Grid Margin="16,12,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="250" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" MinWidth="300" />
            </Grid.ColumnDefinitions>

            <!-- ══════════ LEFT PANEL (RTL = right side): Funds ══════════ -->
            <DockPanel Grid.Column="0">

                <!-- Section header -->
                <TextBlock DockPanel.Dock="Top"
                           Text="קרנות"
                           Style="{StaticResource SectionHeaderStyle}" />

                <!-- Sort controls (E5.10) -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="מיון:"
                               Style="{StaticResource MutedLabelStyle}"
                               Margin="0,0,6,0" />
                    <ComboBox ItemsSource="{Binding SortOptions}"
                              SelectedItem="{Binding SelectedSortOption, Mode=TwoWay}"
                              DisplayMemberPath="Label"
                              Width="120"
                              IsEditable="False" />
                    <Button Content="↑"
                            Command="{Binding MoveSelectedFundUpCommand}"
                            Style="{StaticResource SmallGhostButtonStyle}"
                            Margin="6,0,0,0"
                            ToolTip="הזז למעלה" />
                    <Button Content="↓"
                            Command="{Binding MoveSelectedFundDownCommand}"
                            Style="{StaticResource SmallGhostButtonStyle}"
                            Margin="2,0,0,0"
                            ToolTip="הזז למטה" />
                </StackPanel>

                <!-- Fund operations toolbar -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="הפקדה"
                            Command="{Binding DepositCommand}"
                            CommandParameter="{Binding SelectedFund}"
                            IsEnabled="{Binding CanExecuteFundOperation}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Padding="10,6" />
                    <Button Content="משיכה"
                            Command="{Binding WithdrawCommand}"
                            CommandParameter="{Binding SelectedFund}"
                            IsEnabled="{Binding CanExecuteFundOperation}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="10,6"
                            Margin="4,0,0,0" />
                    <Button Content="העברה"
                            Command="{Binding TransferCommand}"
                            CommandParameter="{Binding SelectedFund}"
                            IsEnabled="{Binding CanExecuteFundOperation}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="10,6"
                            Margin="4,0,0,0" />
                    <Separator Width="1" Margin="8,2" />
                    <Button Content="שנה שם"
                            Command="{Binding RenameFundCommand}"
                            CommandParameter="{Binding SelectedFund}"
                            IsEnabled="{Binding CanExecuteFundOperation}"
                            Style="{StaticResource GhostButtonStyle}"
                            Padding="10,6"
                            Margin="4,0,0,0" />
                    <Button Content="מחק קרן"
                            Command="{Binding DeleteFundCommand}"
                            CommandParameter="{Binding SelectedFund}"
                            IsEnabled="{Binding CanExecuteFundOperation}"
                            Style="{StaticResource DangerButtonStyle}"
                            Padding="10,6"
                            Margin="4,0,0,0" />
                </StackPanel>

                <!-- Loading indicator -->
                <TextBlock DockPanel.Dock="Top"
                           Text="טוען..."
                           HorizontalAlignment="Center"
                           Style="{StaticResource MutedLabelStyle}"
                           Margin="0,8,0,8"
                           Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <!-- Fund list content area -->
                <Grid>
                    <!-- Empty state message -->
                    <TextBlock Text="אין קרנות בתיק זה. לחץ על '+ קרן חדשה' כדי להתחיל."
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="13">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource MutedLabelStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsEmpty}" Value="True" />
                                            <Condition Binding="{Binding IsLoading}" Value="False" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Fund list -->
                    <ListBox x:Name="FundListBox"
                             ItemsSource="{Binding Funds}"
                             SelectedItem="{Binding SelectedFund}"
                             BorderThickness="0"
                             Background="Transparent"
                             HorizontalContentAlignment="Stretch"
                             AlternationCount="3"
                             ItemContainerStyle="{StaticResource CardListBoxItemStyle}">
                        <ListBox.Style>
                            <Style TargetType="ListBox">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Style>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <!--
                                    Card with purple accent bar on the right (RTL leading edge).
                                    ClipToBounds clips the accent bar flush to the card's rounded corners.
                                -->
                                <Border Margin="0,0,0,6"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource CardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        ClipToBounds="True">
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="הפקדה"
                                                      Command="{Binding DataContext.DepositCommand,
                                                          Source={x:Reference FundListBox}}"
                                                      CommandParameter="{Binding}" />
                                            <MenuItem Header="משיכה"
                                                      Command="{Binding DataContext.WithdrawCommand,
                                                          Source={x:Reference FundListBox}}"
                                                      CommandParameter="{Binding}" />
                                            <MenuItem Header="העברה מקרן זו..."
                                                      Command="{Binding DataContext.TransferCommand,
                                                          Source={x:Reference FundListBox}}"
                                                      CommandParameter="{Binding}" />
                                            <Separator />
                                            <MenuItem Header="שנה שם"
                                                      Command="{Binding DataContext.RenameFundCommand,
                                                          Source={x:Reference FundListBox}}"
                                                      CommandParameter="{Binding}" />
                                            <Separator />
                                            <MenuItem Header="מחק"
                                                      Command="{Binding DataContext.DeleteFundCommand,
                                                          Source={x:Reference FundListBox}}"
                                                      CommandParameter="{Binding}" />
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <DockPanel>
                                        <!-- Accent bar: right = visual leading edge in RTL.
                                             Color rotates blue → teal → amber via AlternationCount="3". -->
                                        <Border DockPanel.Dock="Right">
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource AccentBarStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding (ItemsControl.AlternationIndex),
                                                            RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="1">
                                                            <Setter Property="Background" Value="{StaticResource TealBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding (ItemsControl.AlternationIndex),
                                                            RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="2">
                                                            <Setter Property="Background" Value="{StaticResource AmberBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>

                                        <!-- Item content with padding -->
                                        <DockPanel Margin="12,10,8,10">

                                            <!-- Balance -->
                                            <TextBlock DockPanel.Dock="Left"
                                                       Text="{Binding FormattedBalance}"
                                                       Style="{StaticResource FundBalanceStyle}"
                                                       MinWidth="90"
                                                       TextAlignment="Right" />

                                            <!-- Allocation percent -->
                                            <TextBlock DockPanel.Dock="Left"
                                                       Text="{Binding FormattedAllocation}"
                                                       Style="{StaticResource MutedLabelStyle}"
                                                       Margin="10,0,0,0"
                                                       FlowDirection="LeftToRight" />

                                            <!-- Fund name fills remaining space -->
                                            <TextBlock Text="{Binding Name}"
                                                       Style="{StaticResource FundNameStyle}" />
                                        </DockPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

            </DockPanel>

            <!-- Draggable splitter -->
            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{StaticResource SplitterBrush}"
                          Cursor="SizeWE" />

            <!-- ══════════ RIGHT PANEL (RTL = left side): History ══════════ -->
            <DockPanel Grid.Column="2" Margin="8,0,0,0"
                       DataContext="{Binding HistoryViewModel}">

                <!-- Section header -->
                <TextBlock DockPanel.Dock="Top"
                           Text="היסטוריה"
                           Style="{StaticResource SectionHeaderStyle}" />

                <!-- Filter bar -->
                <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <!-- Date range: From -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,8,4">
                        <TextBlock Text="מ:" Style="{StaticResource MutedLabelStyle}" Margin="0,0,4,0" />
                        <DatePicker SelectedDate="{Binding FilterFromDate, Mode=TwoWay}"
                                    FlowDirection="LeftToRight"
                                    Width="120" />
                    </StackPanel>

                    <!-- Date range: To -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,8,4">
                        <TextBlock Text="עד:" Style="{StaticResource MutedLabelStyle}" Margin="0,0,4,0" />
                        <DatePicker SelectedDate="{Binding FilterToDate, Mode=TwoWay}"
                                    FlowDirection="LeftToRight"
                                    Width="120" />
                    </StackPanel>

                    <!-- Fund filter -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,8,4">
                        <TextBlock Text="קרן:" Style="{StaticResource MutedLabelStyle}" Margin="0,0,4,0" />
                        <ComboBox ItemsSource="{Binding FundFilterOptions}"
                                  SelectedItem="{Binding SelectedFundFilter, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayName"
                                  Width="130"
                                  IsEditable="False" />
                    </StackPanel>

                    <!-- Type filter -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,8,4">
                        <TextBlock Text="סוג:" Style="{StaticResource MutedLabelStyle}" Margin="0,0,4,0" />
                        <ComboBox ItemsSource="{Binding TypeFilterOptions}"
                                  SelectedItem="{Binding SelectedTypeFilter, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayLabel"
                                  Width="130"
                                  IsEditable="False" />
                    </StackPanel>

                    <!-- Clear filters -->
                    <Button Content="נקה"
                            Command="{Binding ClearFiltersCommand}"
                            Style="{StaticResource GhostButtonStyle}"
                            Padding="8,4"
                            Margin="0,0,4,4" />

                    <!-- CSV export -->
                    <Button Content="CSV"
                            Command="{Binding ExportCsvCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="8,4"
                            Margin="0,0,0,4" />
                </WrapPanel>

                <!-- History error message -->
                <TextBlock DockPanel.Dock="Top"
                           Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource ErrorBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,4"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />

                <!-- Loading indicator -->
                <TextBlock DockPanel.Dock="Top"
                           Text="טוען היסטוריה..."
                           HorizontalAlignment="Center"
                           Style="{StaticResource MutedLabelStyle}"
                           Margin="0,8,0,8"
                           Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <!-- History content area -->
                <Grid>
                    <!-- Empty state -->
                    <TextBlock Text="אין רשומות היסטוריה."
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="13">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource MutedLabelStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsEmpty}" Value="True" />
                                            <Condition Binding="{Binding IsLoading}" Value="False" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Transaction history list with expandable items -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>
                        <ItemsControl ItemsSource="{Binding Transactions}"
                                      AlternationCount="2">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Background alternates white / very light gray for readability -->
                                    <Border BorderBrush="{StaticResource CardBorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="4,6">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding (ItemsControl.AlternationIndex),
                                                        RelativeSource={RelativeSource AncestorType=ContentPresenter}}" Value="1">
                                                        <Setter Property="Background" Value="#F4F6F9" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Expander IsExpanded="False">
                                            <Expander.Header>
                                                <DockPanel Width="{Binding ActualWidth,
                                                    RelativeSource={RelativeSource AncestorType=ContentPresenter}}"
                                                           Margin="0,0,16,0">

                                                    <!-- Amount — color-coded to match the transaction type label -->
                                                    <TextBlock DockPanel.Dock="Left"
                                                               Text="{Binding FormattedAmount}"
                                                               FontSize="13"
                                                               MinWidth="90"
                                                               TextAlignment="Right">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock" BasedOn="{StaticResource FundBalanceStyle}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding TransactionType}" Value="FundDeposit">
                                                                        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding TransactionType}" Value="FundWithdrawal">
                                                                        <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding TransactionType}" Value="Transfer">
                                                                        <Setter Property="Foreground" Value="{StaticResource TealBrush}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding TransactionType}" Value="PortfolioRevalued">
                                                                        <Setter Property="Foreground" Value="{StaticResource AmberBrush}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding TransactionType}" Value="Undo">
                                                                        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>

                                                    <!-- Date -->
                                                    <TextBlock DockPanel.Dock="Left"
                                                               Style="{StaticResource MutedLabelStyle}"
                                                               Margin="12,0,0,0"
                                                               FlowDirection="LeftToRight">
                                                        <TextBlock.Text>
                                                            <Binding Path="CommittedAtUtc"
                                                                     StringFormat="{}{0:dd/MM/yyyy HH:mm}" />
                                                        </TextBlock.Text>
                                                    </TextBlock>

                                                    <!-- Transaction type icon + label, both color-coded.
                                                         FlowDirection=LTR keeps icon visually left of the Hebrew text. -->
                                                    <StackPanel Orientation="Horizontal"
                                                                VerticalAlignment="Center"
                                                                FlowDirection="LeftToRight">
                                                        <materialDesign:PackIcon Width="18" Height="18"
                                                                                 VerticalAlignment="Center"
                                                                                 Margin="0,0,5,0">
                                                            <materialDesign:PackIcon.Style>
                                                                <Style TargetType="materialDesign:PackIcon">
                                                                    <Setter Property="Kind"       Value="History" />
                                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding TransactionType}" Value="FundDeposit">
                                                                            <Setter Property="Kind"       Value="ArrowDownBold" />
                                                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding TransactionType}" Value="FundWithdrawal">
                                                                            <Setter Property="Kind"       Value="ArrowUpBold" />
                                                                            <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding TransactionType}" Value="Transfer">
                                                                            <Setter Property="Kind"       Value="SwapHorizontal" />
                                                                            <Setter Property="Foreground" Value="{StaticResource TealBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding TransactionType}" Value="PortfolioRevalued">
                                                                            <Setter Property="Kind"       Value="TrendingUp" />
                                                                            <Setter Property="Foreground" Value="{StaticResource AmberBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding TransactionType}" Value="Undo">
                                                                            <Setter Property="Kind"       Value="Undo" />
                                                                            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </materialDesign:PackIcon.Style>
                                                        </materialDesign:PackIcon>
                                                        <TextBlock Text="{Binding TransactionTypeLabel}"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding TransactionType}" Value="FundDeposit">
                                                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding TransactionType}" Value="FundWithdrawal">
                                                                            <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding TransactionType}" Value="Transfer">
                                                                            <Setter Property="Foreground" Value="{StaticResource TealBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding TransactionType}" Value="PortfolioRevalued">
                                                                            <Setter Property="Foreground" Value="{StaticResource AmberBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding TransactionType}" Value="Undo">
                                                                            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </DockPanel>
                                            </Expander.Header>

                                            <!-- Expanded detail area -->
                                            <StackPanel Margin="24,4,0,4">
                                                <!-- Undo button (visible only for undoable operations, E6.12) -->
                                                <Button Content="↩ בטל פעולה"
                                                        ToolTip="ביטול פעולה"
                                                        Command="{Binding DataContext.UndoOperationCommand,
                                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        HorizontalAlignment="Right"
                                                        Padding="8,3"
                                                        Margin="0,0,0,6"
                                                        FontSize="12"
                                                        Visibility="{Binding IsUndoable,
                                                            Converter={StaticResource BooleanToVisibilityConverter}}" />

                                                <!-- Summary text -->
                                                <TextBlock Text="{Binding SummaryText}"
                                                           Style="{StaticResource MutedLabelStyle}"
                                                           Margin="0,0,0,4"
                                                           Visibility="{Binding SummaryText,
                                                               Converter={StaticResource StringToVisibilityConverter}}" />

                                                <!-- Detail rows -->
                                                <ItemsControl ItemsSource="{Binding Details}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <DockPanel Margin="0,2">
                                                                <!-- Left side: before / change / after with Hebrew labels -->
                                                                <StackPanel DockPanel.Dock="Left"
                                                                            Orientation="Horizontal"
                                                                            VerticalAlignment="Center"
                                                                            Margin="0,0,12,0">
                                                                    <TextBlock Text="לפני:"
                                                                               Style="{StaticResource MutedLabelStyle}"
                                                                               VerticalAlignment="Center" />
                                                                    <TextBlock Text="{Binding FormattedBeforeBalance}"
                                                                               Style="{StaticResource MutedLabelStyle}"
                                                                               VerticalAlignment="Center"
                                                                               Margin="2,0,0,0"
                                                                               FlowDirection="LeftToRight"
                                                                               MinWidth="70"
                                                                               TextAlignment="Right" />
                                                                    <TextBlock Text=" — "
                                                                               Style="{StaticResource MutedLabelStyle}"
                                                                               VerticalAlignment="Center" />
                                                                    <TextBlock Text="שינוי:"
                                                                               Style="{StaticResource MutedLabelStyle}"
                                                                               VerticalAlignment="Center" />
                                                                    <TextBlock Text="{Binding FormattedSignedAmount}"
                                                                               FontSize="12"
                                                                               Foreground="{Binding AmountAgoras, Converter={StaticResource SignedAmountToBrushConverter}}"
                                                                               VerticalAlignment="Center"
                                                                               Margin="2,0,0,0"
                                                                               FlowDirection="LeftToRight"
                                                                               MinWidth="70"
                                                                               TextAlignment="Right" />
                                                                    <TextBlock Text=" — "
                                                                               Style="{StaticResource MutedLabelStyle}"
                                                                               VerticalAlignment="Center" />
                                                                    <TextBlock Text="אחרי:"
                                                                               Style="{StaticResource MutedLabelStyle}"
                                                                               VerticalAlignment="Center" />
                                                                    <TextBlock Text="{Binding FormattedAfterBalance}"
                                                                               Style="{StaticResource MutedLabelStyle}"
                                                                               VerticalAlignment="Center"
                                                                               Margin="2,0,0,0"
                                                                               FlowDirection="LeftToRight"
                                                                               MinWidth="70"
                                                                               TextAlignment="Right" />
                                                                </StackPanel>

                                                                <!-- Right side (fill): fund name + detail type -->
                                                                <TextBlock VerticalAlignment="Center"
                                                                           FontSize="12"
                                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                                           TextTrimming="CharacterEllipsis">
                                                                    <Run Text="{Binding FundName, Mode=OneWay}" />
                                                                    <Run Text=" — " Foreground="{StaticResource TextMutedBrush}" />
                                                                    <Run Text="{Binding TransactionTypeLabel, Mode=OneWay}"
                                                                         Foreground="{StaticResource TextMutedBrush}" />
                                                                </TextBlock>
                                                            </DockPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Expander>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

            </DockPanel>

        </Grid>

    </DockPanel>
</Window>
