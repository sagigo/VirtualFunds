<Window x:Class="VirtualFunds.WPF.Views.NameInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="תיק חדש"
        Height="220"
        Width="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FlowDirection="RightToLeft"
        Background="{StaticResource BackgroundBrush}"
        TextElement.Foreground="{StaticResource TextPrimaryBrush}"
        TextElement.FontFamily="{materialDesign:MaterialDesignFont}">

    <DockPanel>
        <!-- Purple accent strip at top of dialog -->
        <Border DockPanel.Dock="Top"
                Height="4"
                Background="{StaticResource PrimaryBrush}" />

        <!-- Form content -->
        <Border Style="{StaticResource DialogCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Label -->
                <TextBlock Grid.Row="0"
                           Text="שם התיק:"
                           Style="{StaticResource FieldLabelStyle}" />

                <!-- Name input -->
                <TextBox Grid.Row="1"
                         x:Name="NameTextBox"
                         Margin="0,0,0,12"
                         MaxLength="100"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" />

                <!-- Buttons -->
                <StackPanel Grid.Row="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left">
                    <Button Content="אישור"
                            MinWidth="70"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Padding="12,6"
                            Margin="0,0,8,0"
                            IsDefault="True"
                            Click="OkButton_Click" />
                    <Button Content="ביטול"
                            MinWidth="70"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="12,6"
                            IsCancel="True" />
                </StackPanel>
            </Grid>
        </Border>
    </DockPanel>
</Window>
